# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Default AI model (optional, default: claude-sonnet-4.6)
DEFAULT_AI_MODEL=claude-sonnet-4.6

# Default reasoning effort (optional: low, medium, high, xhigh)
DEFAULT_REASONING_EFFORT=

# xAI Grok API key (required for /grok)
XAI_API_KEY=

# Default Grok model (optional, default: grok-4-1-fast-reasoning)
DEFAULT_GROK_MODEL=grok-4-1-fast-reasoning
